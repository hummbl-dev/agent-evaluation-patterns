{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/agent-evaluation-patterns-v0.1.json",
  "title": "Agent Evaluation Patterns Packet v0.1",
  "description": "Minimal schema for a version-controlled, reviewable agent evaluation packet.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packetStatus",
    "evaluationManifest",
    "authority",
    "evaluationContract",
    "receiptRequirements"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1"
    },
    "packetStatus": {
      "type": "string",
      "enum": ["draft", "candidate", "adopted", "deprecated"]
    },
    "evaluationManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "version", "scope"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["author", "owner"],
      "properties": {
        "author": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evaluationContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taskSuite", "rubric", "judgeConfig", "statisticalRequirements"],
      "properties": {
        "taskSuite": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tasks"],
          "properties": {
            "tasks": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "prompt", "successCondition"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "prompt": { "type": "string", "minLength": 1 },
                  "successCondition": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        "rubric": {
          "type": "object",
          "additionalProperties": false,
          "required": ["criteria"],
          "properties": {
            "criteria": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "description", "weight"],
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "description": { "type": "string", "minLength": 1 },
                  "weight": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              }
            }
          }
        },
        "judgeConfig": {
          "type": "object",
          "additionalProperties": false,
          "required": ["judgeType"],
          "properties": {
            "judgeType": {
              "type": "string",
              "enum": ["model", "human", "hybrid", "programmatic"]
            },
            "judgeModel": { "type": "string" },
            "temperature": { "type": "number", "minimum": 0, "maximum": 2 }
          }
        },
        "statisticalRequirements": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minSamples", "confidenceLevel"],
          "properties": {
            "minSamples": { "type": "integer", "minimum": 1 },
            "confidenceLevel": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "receiptRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mustRecord"],
      "properties": {
        "mustRecord": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
